# MockAPI - CRUD de produtos
# Crie um projeto em https://mockapi.io e um recurso "products".
# Copie este arquivo para .env e preencha com a URL base do seu projeto.
# A URL base termina em /api/v1 (sem barra final e sem o nome do recurso).
EXPO_PUBLIC_MOCKAPI_BASE_URL=https://SEU_PROJETO.mockapi.io/api/v1

# Opcional: nome do recurso no MockAPI (padrão: products)
EXPO_PUBLIC_MOCKAPI_PRODUCTS_RESOURCE=products

# Opcional: webhook usado pelas notificações push do carrinho
# EXPO_PUBLIC_PUSH_WEBHOOK_URL=
# EXPO_PUBLIC_PUSH_WEBHOOK_SECRET=
